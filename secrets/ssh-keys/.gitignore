# Ignore unencrypted SSH private keys
# Only sops-encrypted keys in secrets.yaml should be committed

# Private keys
*_ed25519
*_rsa
*_ecdsa
id_*
*.key
*.pem

# Exclude .pub files from ignore (public keys are OK)
!*.pub

# Temporary files
*.backup
*.tmp
*.old
*.new

# Working directories with potentially unencrypted content
hosts/*/temp/
hosts/*/backup/
