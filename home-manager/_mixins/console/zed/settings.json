{
  // Zed Editor Configuration
  // Mirroring Neovim setup for consistency

  // Remote development via SSH -- "host" here must resolve through the
  // NORMAL ssh config resolution (~/.ssh/config, which Includes
  // ~/.ssh/agent-sandbox-ec2.conf), same as a plain `ssh asx-<workspace>`
  // would. agent-sandbox's ec2 tier keeps that alias pointed at whatever
  // IP the box currently has (rewritten on every `up`/`connect`) -- so
  // this entry survives the box being stopped/restarted with a new IP,
  // as long as Zed is told to (re)connect AFTER the alias has been
  // refreshed (i.e. after running `agent-sandbox --tier ec2 connect`
  // once from a terminal first). Zed does NOT prompt for a remote path
  // separately -- after connecting it opens directly into project
  // selection on the projects list below.
  "ssh_connections": [
    {
      "host": "asx-bcs",
      "projects": [
        { "paths": ["~/ws/postgres/bcs"] }
      ]
    }
  ],

  // Theme and appearance
  "theme": "Gruvbox Dark Hard",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_features": {
    "calt": true
  },
  "buffer_line_height": "comfortable",

  // Editor behavior
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "off",

  // Line numbers and gutter
  "relative_line_numbers": false,
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "folds": true
  },

  // Scrolling
  "scroll_beyond_last_line": "one_page",
  "scrollbar": {
    "show": "always",
    "git_diff": true,
    "selected_symbol": true,
    "diagnostics": true
  },

  // Cursor
  "cursor_blink": false,

  // Terminal
  "terminal": {
    "shell": {
      "program": "fish"
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "line_height": "comfortable"
  },

  // Git integration
  "git": {
    "enabled": true,
    "auto_fetch": true,
    "git_gutter": "tracked_files"
  },

  // Collaboration
  "collaboration_panel": {
    "button": false
  },

  // Project panel
  "project_panel": {
    "button": true,
    "default_width": 300,
    "dock": "left",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20
  },

  // Outline panel
  "outline_panel": {
    "button": true,
    "default_width": 300,
    "dock": "right"
  },

  // Inlay hints
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },

  // Diagnostics
  "diagnostics": {
    "include_warnings": true
  },

  // LSP configuration
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "cargo": {
          "features": "all"
        }
      }
    },
    "clangd": {
      "binary": {
        "path": "clangd"
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  },

  // Language-specific settings
  "languages": {
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "C": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "C++": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["-"]
        }
      },
      "hard_tabs": false
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "Markdown": {
      "tab_size": 2,
      "format_on_save": "off",
      "hard_tabs": false,
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 80
    },
    "Shell Script": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-"]
        }
      },
      "hard_tabs": false
    },
    "SQL": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pgformatter",
          "arguments": []
        }
      },
      "hard_tabs": false
    },
    "Nix": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "nixpkgs-fmt",
          "arguments": []
        }
      },
      "hard_tabs": false
    }
  },

  // File associations
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "JSON": ["*.json", "*.jsonc"],
    "Shell Script": ["*.sh", "*.bash", "*.zsh"]
  },

  // AI / LLM configuration
  //
  // AI is ENABLED and routed exclusively through our per-host LiteLLM
  // gateway (the same Bedrock proxy the CLI agents use) — nothing reaches
  // Anthropic/OpenAI/zed.dev directly. Telemetry is OFF on every channel
  // (see "telemetry" below). The first time you open the agent panel, pick
  // provider "LiteLLM" (OpenAI Compatible) and paste a per-agent LiteLLM
  // key; Zed stores it in the OS keychain, never in this file.
  "disable_ai": false,
  "agent": {
    "enabled": true,
    "button": false,
    "default_model": {
      "provider": "openai_compatible",
      "model": "claude-opus-4-8"
    },
    // "yolo" mode: auto-approve agent tool actions without prompting
    // (default "allow"), so the agent runs end-to-end unattended — EXCEPT
    // the destructive patterns below still require confirmation or are
    // denied outright, matching the global must-rules (no force-push, no
    // hard reset, trash-not-rm, don't touch secrets). Loosen freely; keep
    // the guards.
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "allow",
          "always_confirm": [
            { "pattern": "git\\s+push\\s+(-f|--force|--force-with-lease)" },
            { "pattern": "git\\s+(reset|clean)\\s+--hard" },
            { "pattern": "git\\s+rebase" },
            { "pattern": "git\\s+commit\\s+--amend" },
            { "pattern": "\\brm\\s+-rf?\\b" },
            { "pattern": "\\b(mkfs|dd)\\b" },
            { "pattern": "\\|\\s*(sudo\\s+)?(sh|bash)\\b" }
          ]
        },
        "edit_file": {
          "default": "allow",
          "always_deny": [
            { "pattern": "\\.env($|\\.)" },
            { "pattern": "secrets?/" },
            { "pattern": "\\.pem$" },
            { "pattern": "\\.key$" }
          ]
        }
      }
    }
  },
  // Edit predictions also go through the local gateway; keep them on.
  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed"
  },
  // OpenAI-compatible provider -> loopback LiteLLM gateway. api_url only;
  // key is entered via Zed's UI and kept in the OS keychain.
  "language_models": {
    "openai_compatible": {
      "LiteLLM": {
        "api_url": "http://127.0.0.1:4000/v1",
        "available_models": [
          { "name": "claude-opus-4-8", "max_tokens": 200000 },
          { "name": "claude-sonnet-5", "max_tokens": 200000 },
          { "name": "claude-fable-5", "max_tokens": 200000 }
        ]
      }
    }
  },
  // Telemetry: OFF, all channels.
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // Vim mode
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },

  // Preview tabs
  "preview_tabs": {
    "enabled": true
  },

  // Auto-update
  "auto_update": false
}
