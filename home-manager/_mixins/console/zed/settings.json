{
  // Zed Editor Configuration
  // Mirroring Neovim setup for consistency

  // Theme and appearance
  "theme": "Gruvbox Dark Hard",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_features": {
    "calt": true
  },
  "buffer_line_height": "comfortable",

  // Editor behavior
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "off",

  // Line numbers and gutter
  "relative_line_numbers": false,
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "folds": true
  },

  // Scrolling
  "scroll_beyond_last_line": "one_page",
  "scrollbar": {
    "show": "always",
    "git_diff": true,
    "selected_symbol": true,
    "diagnostics": true
  },

  // Cursor
  "cursor_blink": false,

  // Terminal
  "terminal": {
    "shell": {
      "program": "fish"
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "line_height": "comfortable"
  },

  // Git integration
  "git": {
    "enabled": true,
    "auto_fetch": true,
    "git_gutter": "tracked_files"
  },

  // Collaboration
  "collaboration_panel": {
    "button": false
  },

  // Project panel
  "project_panel": {
    "button": true,
    "default_width": 300,
    "dock": "left",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20
  },

  // Outline panel
  "outline_panel": {
    "button": true,
    "default_width": 300,
    "dock": "right"
  },

  // Inlay hints
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },

  // Diagnostics
  "diagnostics": {
    "include_warnings": true
  },

  // LSP configuration
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "cargo": {
          "features": "all"
        }
      }
    },
    "clangd": {
      "binary": {
        "path": "clangd"
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  },

  // Language-specific settings
  "languages": {
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "C": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "C++": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "hard_tabs": false
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["-"]
        }
      },
      "hard_tabs": false
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
      "hard_tabs": false
    },
    "Markdown": {
      "tab_size": 2,
      "format_on_save": "off",
      "hard_tabs": false,
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 80
    },
    "Shell Script": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-"]
        }
      },
      "hard_tabs": false
    },
    "SQL": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pgformatter",
          "arguments": []
        }
      },
      "hard_tabs": false
    },
    "Nix": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "nixpkgs-fmt",
          "arguments": []
        }
      },
      "hard_tabs": false
    }
  },

  // File associations
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "JSON": ["*.json", "*.jsonc"],
    "Shell Script": ["*.sh", "*.bash", "*.zsh"]
  },

  // AI / LLM configuration
  //
  // Telemetry is OFF (see "telemetry" below). The AI panel + edit
  // predictions are disabled by default so Zed does NOT auto-connect to
  // zed.dev on startup (that was the failed network call). If you DO want
  // to use AI in Zed, it is pre-wired to our per-host LiteLLM gateway via
  // the `openai_compatible` provider below: open the agent panel, pick
  // provider "OpenAI Compatible", and paste any per-agent LiteLLM key
  // (Zed stores it in the OS keychain, never in this file). Nothing here
  // reaches Anthropic/OpenAI/zed.dev directly.
  "disable_ai": false,
  "agent": {
    "enabled": false,
    "button": false
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    // Keep the provider local-only; the agent panel above is disabled so
    // this never fires unless you explicitly turn AI features back on.
    "provider": "zed"
  },
  // Point Zed's OpenAI-compatible LLM provider at the loopback LiteLLM
  // gateway (same proxy the CLI agents use). api_url only — the key is
  // entered via Zed's UI and kept in the OS keychain.
  "language_models": {
    "openai_compatible": {
      "LiteLLM": {
        "api_url": "http://127.0.0.1:4000/v1"
      }
    }
  },
  // Telemetry: OFF, all channels.
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // Vim mode
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },

  // Preview tabs
  "preview_tabs": {
    "enabled": true
  },

  // Auto-update
  "auto_update": false
}
