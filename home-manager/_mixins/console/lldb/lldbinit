# LLDB initialization file for PostgreSQL development
# Place in ~/.lldbinit or source from project-specific .lldbinit

# Settings
settings set target.process.follow-fork-mode child
settings set target.process.detach-on-fork true
settings set target.disable-aslr false
settings set stop-line-count-before 3
settings set stop-line-count-after 3

# History
settings set target.preload-symbols true
settings set interpreter.save-session-on-quit true

# Display settings
settings set frame-format frame #${frame.index}: ${frame.pc}{ ${module.file.basename}{`${function.name-with-args}${function.pc-offset}}}{ at ${line.file.basename}:${line.number}}\n
settings set thread-format thread #${thread.index}: tid = ${thread.id}{, ${frame.pc}}{, name = ${thread.name}}{, queue = ${thread.queue}}{, stop reason = ${thread.stop-reason}}\n

# Source-level debugging
settings set stop-disassembly-display never
settings set target.prefer-dynamic-value no-dynamic-values

# PostgreSQL-specific type summaries and synthetic children
# These help visualize PostgreSQL data structures

# Command aliases for common PostgreSQL debugging tasks
command alias pbt thread backtrace all
command alias pf frame select
command alias pv frame variable
command alias pl process list

# Custom commands for PostgreSQL structures

command script import lldb

# Python scripts for PostgreSQL pretty printing
script
import lldb
import os
import sys

def __lldb_init_module(debugger, internal_dict):
    # Add PostgreSQL source directory to path if it exists
    pg_source = os.path.expanduser("~/src/postgresql")
    lldb_pp_path = os.path.join(pg_source, "src/tools/lldb")

    if os.path.exists(lldb_pp_path):
        sys.path.insert(0, lldb_pp_path)
        try:
            import pg_lldb_printers
            pg_lldb_printers.register_printers(debugger)
            print("PostgreSQL LLDB pretty printers loaded")
        except ImportError:
            print("PostgreSQL LLDB pretty printers not found")

    print("PostgreSQL LLDB configuration loaded")

# Helper function to print PostgreSQL Node structures
def print_node(debugger, command, result, internal_dict):
    """Print a PostgreSQL Node structure"""
    target = debugger.GetSelectedTarget()
    process = target.GetProcess()
    thread = process.GetSelectedThread()
    frame = thread.GetSelectedFrame()

    if not command:
        result.AppendMessage("Usage: pnode <variable_name>")
        return

    var = frame.FindVariable(command)
    if var.IsValid():
        result.AppendMessage(str(var))
    else:
        result.AppendMessage(f"Variable '{command}' not found")

