# Helper function to attach to PostgreSQL backend
def attach_backend(debugger, command, result, internal_dict):
    """Attach to a PostgreSQL backend process"""
    if not command:
        result.AppendMessage("Usage: pbackend <pid>")
        return

    try:
        pid = int(command)
        target = debugger.CreateTarget("")
        error = lldb.SBError()
        process = target.AttachToProcessWithID(debugger.GetListener(), pid, error)
        if error.Success():
            result.AppendMessage(f"Attached to PostgreSQL backend {pid}")
        else:
            result.AppendMessage(f"Failed to attach: {error.GetCString()}")
    except ValueError:
        result.AppendMessage("Invalid PID")

# Register custom commands
lldb.debugger.HandleCommand('command script add -f lldbinit.print_node pnode')
lldb.debugger.HandleCommand('command script add -f lldbinit.print_list plist')
lldb.debugger.HandleCommand('command script add -f lldbinit.print_query pquery')
lldb.debugger.HandleCommand('command script add -f lldbinit.attach_backend pbackend')

# Common breakpoint shortcuts
def break_exec(debugger, command, result, internal_dict):
    """Set breakpoint at exec_simple_query"""
    debugger.HandleCommand('breakpoint set --name exec_simple_query')

def break_plan(debugger, command, result, internal_dict):
    """Set breakpoint at standard_planner"""
    debugger.HandleCommand('breakpoint set --name standard_planner')

def break_parse(debugger, command, result, internal_dict):
    """Set breakpoint at raw_parser"""
    debugger.HandleCommand('breakpoint set --name raw_parser')

def break_error(debugger, command, result, internal_dict):
    """Set breakpoint at errfinish"""
    debugger.HandleCommand('breakpoint set --name errfinish')

def break_elog(debugger, command, result, internal_dict):
    """Set breakpoint at elog_finish"""
    debugger.HandleCommand('breakpoint set --name elog_finish')

# Register breakpoint shortcuts
lldb.debugger.HandleCommand('command script add -f lldbinit.break_exec bexec')
lldb.debugger.HandleCommand('command script add -f lldbinit.break_plan bplan')
lldb.debugger.HandleCommand('command script add -f lldbinit.break_parse bparse')
lldb.debugger.HandleCommand('command script add -f lldbinit.break_error berror')
lldb.debugger.HandleCommand('command script add -f lldbinit.break_elog belog')

print("Custom PostgreSQL commands loaded:")
print("  pnode <var> - Print PostgreSQL Node")
print("  plist <var> - Print PostgreSQL List")
print("  pquery <var> - Print PostgreSQL Query")
print("  pbackend <pid> - Attach to backend process")
print("  bexec, bplan, bparse, berror, belog - Common breakpoints")
script

